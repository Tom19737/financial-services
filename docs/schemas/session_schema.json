{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SessionJournal",
  "description": "Schema for a single research or discussion session including decisions made.",
  "type": "object",
  "properties": {
    "session_id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}-[0-9]{2}_[A-Za-z0-9\\.\\-_]+_[A-Za-z0-9\\.\\-_]+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "ticker": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "company": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workflow": {
      "type": "string"
    },
    "trigger": {
      "type": "string",
      "enum": ["auto", "manual"]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "price_at_session": {
      "type": ["number", "null"]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": ["assumption", "scenario", "methodology", "conclusion", "risk"]
          },
          "topic": {
            "type": "string"
          },
          "question": {
            "type": "string"
          },
          "chosen": {
            "type": "string"
          },
          "alternatives": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string"
                },
                "reason_rejected": {
                  "type": "string"
                }
              },
              "required": ["value", "reason_rejected"]
            }
          },
          "rationale": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "impact": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        },
        "required": ["id", "category", "topic", "question", "chosen", "rationale", "confidence", "impact"]
      }
    }
  },
  "required": [
    "session_id",
    "date",
    "ticker",
    "company",
    "workflow",
    "trigger",
    "tags",
    "confidence",
    "artifacts",
    "decisions"
  ]
}
